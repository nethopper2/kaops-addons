/.idea
.DS_Store
.thumbs.db
node_modules
.vscode

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Terraform
*.tfstate
*.tfvars
.terraform*

# global
**/.env
envs/

# Local test values files
# These files are used for local testing and should not be committed to the repository.
test-values.yaml

# Chart dependencies files
Chart.lock
charts/*/charts/*
# OpenReplay vendors its upstream subcharts into the repo (commit-time vendoring)
# because OpenReplay does not publish a Helm registry. Refresh via scripts/vendor-openreplay.sh.
!charts/openreplay/charts/
!charts/openreplay/charts/**

# Pipeline files (copied from private repo during CI/CD build)
charts/private-ai-rag/pipelines/*.py

# Claude files
.claude
CLAUDE.md